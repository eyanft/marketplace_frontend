{
  "expo": {
    "name": "Mercx",
    "slug": "mercs-marketplace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "marketplace",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.wevioo.marketplace",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "expo-notifications",
      "expo-dev-client",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to search for products."
        }
      ],
      "expo-font",
      [
        "react-native-fbsdk-next",
        {
          "appID": "1392643338747456",
          "clientToken": "393daedb479f9f941d5b6228ec0aee5a",
          "displayName": "marketplace",
          "scheme": "fb1392643338747456"
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b786c547-e0e0-4d33-b800-75deac2b6752"
      }
    },
    "owner": "spawn005"
  }
}
